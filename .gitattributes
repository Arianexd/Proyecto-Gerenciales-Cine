# Auto detect text files and perform LF normalization
* text=auto

# JavaScript & TypeScript
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf

# CSS
*.css text eol=lf
*.scss text eol=lf

# Markdown
*.md text eol=lf

# Config files
.env.* text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf

# Archives
*.zip binary
*.tar binary
*.gz binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary



